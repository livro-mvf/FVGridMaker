PROJECT_NAME           = "FVGridMaker"
PROJECT_NUMBER         = "@PROJECT_VERSION@"
OUTPUT_DIRECTORY       = "@FVG_DOXYGEN_OUTPUT_DIR@"
INPUT                  = "@PROJECT_SOURCE_DIR@/FVGridMakerLib/include"
RECURSIVE              = YES
FILE_PATTERNS           = *.h *.hpp
GENERATE_HTML           = NO
GENERATE_XML            = YES
XML_OUTPUT              = xml
OUTPUT_LANGUAGE         = Portuguese
EXTRACT_ALL             = YES
EXTRACT_PRIVATE         = NO
EXTRACT_STATIC          = YES
HIDE_UNDOC_MEMBERS      = NO
HIDE_UNDOC_CLASSES      = NO
SOURCE_BROWSER          = YES
REFERENCED_BY_RELATION  = YES
REFERENCES_RELATION     = YES
FULL_PATH_NAMES         = NO
STRIP_FROM_PATH         = "@PROJECT_SOURCE_DIR@"
QUIET                   = YES
WARN_IF_UNDOCUMENTED    = NO
WARN_IF_DOC_ERROR       = YES
WARN_AS_ERROR           = NO
ENABLE_PREPROCESSING    = YES
MACRO_EXPANSION         = YES
