#pragma once

// ----------------------------------------------------------------------------
// C++ standard library includes
// ----------------------------------------------------------------------------
#include <cstdint>
#include <string>
#include <string_view>

namespace fvgrid::build_info {

struct VersionInfo final {
    static constexpr std::uint32_t kMajor = @FVG_PROJECT_VERSION_MAJOR@;
    static constexpr std::uint32_t kMinor = @FVG_PROJECT_VERSION_MINOR@;
    static constexpr std::uint32_t kPatch = @FVG_PROJECT_VERSION_PATCH@;
    static constexpr std::uint32_t kTweak = @FVG_PROJECT_VERSION_TWEAK@;

    static constexpr std::string_view kGitHash = "@FVG_GIT_HASH@";
    static constexpr std::string_view kGitBranch = "@FVG_GIT_BRANCH@";
    static constexpr std::string_view kGitDirtySuffix =
        "@FVG_GIT_DIRTY_SUFFIX@";

    static constexpr std::string_view kBuildTimestamp =
        "@FVG_BUILD_TIMESTAMP@";
    static constexpr std::string_view kBuildDate = "@FVG_BUILD_DATE@";

    static constexpr std::string_view kSemanticVersion =
        "@FVG_VERSION_SEMANTIC@";
    static constexpr std::string_view kFullVersion = "@FVG_VERSION_FULL@";

    [[nodiscard]] static std::string to_string() {
        return std::string{kFullVersion};
    }

    [[nodiscard]] static std::string semantic_string() {
        return std::string{kSemanticVersion};
    }

    [[nodiscard]] static constexpr std::uint32_t to_integer() noexcept {
        return (kMajor << 16) | (kMinor << 8) | kPatch;
    }

    [[nodiscard]] static constexpr bool is_development_build() noexcept {
        return kGitDirtySuffix == "-dirty";
    }

    [[nodiscard]] static constexpr bool is_tagged_release() noexcept {
        return kGitDirtySuffix.empty() &&
               kFullVersion.find('+') == std::string_view::npos &&
               kFullVersion.find('-') == std::string_view::npos;
    }
};

}  // namespace fvgrid::build_info